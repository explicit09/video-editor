{
  "id": "video_processing_suite",
  "description": "Exercise video processing and reframing tools on an imported video clip.",
  "eligibility_tags": [],
  "declared_tools": [
    "clear_project",
    "import_media",
    "add_to_timeline",
    "get_state",
    "apply_lut",
    "apply_person_mask",
    "auto_reframe",
    "chroma_key",
    "denoise_video",
    "stabilize_video",
    "track_object",
    "verify_playback",
    "take_screenshot",
    "set_zoom"
  ],
  "steps": [
    { "id": "clear_project", "op": "tool", "tool": "clear_project" },
    { "id": "stage_asset", "op": "stage_corpus_asset" },
    { "id": "snapshot_assets", "op": "snapshot_assets", "var": "pre_import_assets" },
    { "id": "import_media", "op": "tool", "tool": "import_media", "args": { "file_path": "${context.staged_file_path}" } },
    { "id": "resolve_asset", "op": "resolve_imported_asset", "from": "pre_import_assets" },
    { "id": "add_to_timeline", "op": "tool", "tool": "add_to_timeline", "args": { "asset_id": "${context.asset.id}" } },
    { "id": "state_initial", "op": "capture_editor_state", "var": "state_initial" },
    { "id": "main_video_track", "op": "select_track", "state_var": "state_initial", "type": "video", "var": "main_video_track" },
    { "id": "main_video_clip", "op": "select_clip", "state_var": "state_initial", "track_var": "main_video_track", "var": "main_video_clip" },
    { "id": "apply_lut", "op": "tool", "tool": "apply_lut", "args": { "clip_id": "${context.main_video_clip.id}", "lut_path": "${config.tools_root}/eval_system/assets/identity_test_lut.cube" }, "expect_any": ["LUT configured:"] },
    { "id": "apply_person_mask", "op": "tool", "tool": "apply_person_mask", "args": { "clip_id": "${context.main_video_clip.id}", "action": "isolate" }, "expect_any": ["Person mask applied"] },
    { "id": "auto_reframe", "op": "tool", "tool": "auto_reframe", "args": { "asset_id": "${context.asset.id}", "aspect_ratio": "9:16" }, "expect_any": ["Auto reframe:"] },
    { "id": "chroma_key", "op": "tool", "tool": "chroma_key", "args": { "clip_id": "${context.main_video_clip.id}", "target_hue": 0.33, "tolerance": 0.12 }, "expect_any": ["Chroma key:"] },
    { "id": "denoise_video", "op": "tool", "tool": "denoise_video", "args": { "clip_id": "${context.main_video_clip.id}", "level": 0.45 }, "expect_any": ["Video denoise:"] },
    { "id": "stabilize_video", "op": "tool", "tool": "stabilize_video", "args": { "asset_id": "${context.asset.id}", "smoothing": 0.75 }, "expect_any": ["Stabilization:"] },
    { "id": "track_object", "op": "tool", "tool": "track_object", "args": { "asset_id": "${context.asset.id}", "track_type": "face", "start_time": 0 }, "expect_any": ["Tracked:", "No face detected."] },
    { "id": "verify_playback", "op": "tool", "tool": "verify_playback", "args": { "mode": "quick" }, "save_as": "verify_playback_output", "timeout_seconds": 300 },
    { "id": "timeline_after_video_processing", "op": "capture", "label": "timeline_after_video_processing", "zoom": "fit" }
  ],
  "validators": [
    { "id": "verify_playback_clean", "source": "verify_playback" }
  ],
  "judges": [
    {
      "id": "video_processing_timeline_sanity",
      "rubric_id": "timeline_visual_sanity",
      "artifact_labels": ["timeline_after_video_processing"],
      "prompt": "You are grading a video editor timeline screenshot after video processing operations. Respond with JSON only using keys status, score, confidence, explanation. Grade whether the timeline remains coherent, readable, and visually stable after reframing and clip-processing operations."
    }
  ]
}
