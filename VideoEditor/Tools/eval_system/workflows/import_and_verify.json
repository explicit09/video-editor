{
  "id": "import_and_verify",
  "description": "Import a corpus item into the editor, add it to the timeline, verify playback, and capture the resulting timeline state.",
  "eligibility_tags": [],
  "declared_tools": [
    "clear_project",
    "import_media",
    "add_to_timeline",
    "verify_playback",
    "take_screenshot",
    "set_zoom"
  ],
  "steps": [
    { "id": "clear_project", "op": "tool", "tool": "clear_project" },
    { "id": "stage_asset", "op": "stage_corpus_asset" },
    { "id": "snapshot_assets", "op": "snapshot_assets", "var": "pre_import_assets" },
    { "id": "import_media", "op": "tool", "tool": "import_media", "args": { "file_path": "${context.staged_file_path}" } },
    { "id": "resolve_asset", "op": "resolve_imported_asset", "from": "pre_import_assets" },
    { "id": "add_to_timeline", "op": "tool", "tool": "add_to_timeline", "args": { "asset_id": "${context.asset.id}" } },
    { "id": "verify_playback", "op": "tool", "tool": "verify_playback", "args": { "mode": "quick" }, "save_as": "verify_playback_output" },
    { "id": "timeline_after_import", "op": "capture", "label": "timeline_after_import", "zoom": "fit" }
  ],
  "validators": [
    { "id": "verify_playback_clean", "source": "verify_playback" }
  ],
  "judges": [
    {
      "id": "timeline_visual_sanity",
      "rubric_id": "timeline_visual_sanity",
      "artifact_labels": ["timeline_after_import"],
      "prompt": "You are grading a video editor timeline screenshot. Respond with JSON only using keys status, score, confidence, explanation. Status must be pass, fail, or quarantine. Grade whether the timeline looks coherent and not obviously broken: clips visible, lanes readable, no blank/broken rendering, and no obvious layout corruption."
    }
  ]
}
