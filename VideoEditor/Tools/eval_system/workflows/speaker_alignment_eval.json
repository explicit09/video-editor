{
  "id": "speaker_alignment_eval",
  "description": "Import an AVA-style corpus item, transcribe it, and benchmark multimodal judges on whether visible speaker and speech appear aligned.",
  "eligibility_tags": ["speaker-alignment"],
  "declared_tools": [
    "clear_project",
    "import_media",
    "transcribe_asset",
    "take_screenshot"
  ],
  "steps": [
    { "id": "clear_project", "op": "tool", "tool": "clear_project" },
    { "id": "stage_asset", "op": "stage_corpus_asset" },
    { "id": "snapshot_assets", "op": "snapshot_assets", "var": "pre_import_assets" },
    { "id": "import_media", "op": "tool", "tool": "import_media", "args": { "file_path": "${context.staged_file_path}" } },
    { "id": "resolve_asset", "op": "resolve_imported_asset", "from": "pre_import_assets" },
    { "id": "transcribe_asset", "op": "tool", "tool": "transcribe_asset", "args": { "asset_id": "${context.asset.id}" } },
    { "id": "speaker_probe", "op": "capture", "label": "speaker_probe" }
  ],
  "validators": [],
  "judges": [
    {
      "id": "speaker_alignment",
      "rubric_id": "speaker_alignment",
      "artifact_labels": ["speaker_probe"],
      "prompt": "You are grading whether the visible on-screen person appears to be the active speaker. Respond with JSON only using keys status, score, confidence, explanation. If the screenshot is insufficient to decide, set status to quarantine."
    }
  ]
}
