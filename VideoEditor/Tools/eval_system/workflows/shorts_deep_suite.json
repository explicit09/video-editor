{
  "id": "shorts_deep_suite",
  "description": "Exercise one-click short creation and validate the short can export for a vertical platform.",
  "eligibility_tags": ["has-audio"],
  "declared_tools": [
    "clear_project",
    "import_media",
    "add_to_timeline",
    "transcribe_asset",
    "make_short",
    "export_for_platform",
    "take_screenshot",
    "set_zoom"
  ],
  "steps": [
    { "id": "clear_project", "op": "tool", "tool": "clear_project" },
    { "id": "stage_asset", "op": "stage_corpus_asset" },
    { "id": "snapshot_assets", "op": "snapshot_assets", "var": "pre_import_assets" },
    { "id": "import_media", "op": "tool", "tool": "import_media", "args": { "file_path": "${context.staged_file_path}" } },
    { "id": "resolve_asset", "op": "resolve_imported_asset", "from": "pre_import_assets" },
    { "id": "add_to_timeline", "op": "tool", "tool": "add_to_timeline", "args": { "asset_id": "${context.asset.id}" } },
    { "id": "transcribe_asset", "op": "tool", "tool": "transcribe_asset", "args": { "asset_id": "${context.asset.id}" }, "expect_any_regex": ["Transcribed:", "Already transcribed\\."] },
    { "id": "make_short", "op": "tool", "tool": "make_short", "args": { "asset_id": "${context.asset.id}", "source_start": 5, "source_end": 35, "layout": "auto" }, "expect_any": ["Short ready at 1080x1920."] },
    { "id": "timeline_after_make_short", "op": "capture", "label": "timeline_after_make_short", "zoom": "fit" },
    { "id": "export_for_platform", "op": "tool", "tool": "export_for_platform", "args": { "platform": "youtube_shorts", "filename": "${run.id}" }, "save_as": "export_output" }
  ],
  "validators": [
    { "id": "export_exists", "artifact": "export_output" },
    { "id": "duration_sanity", "artifact": "export_output", "minimum_seconds": 5.0 },
    { "id": "audio_present", "artifact": "export_output", "required": true, "expected_from_probe": true },
    { "id": "no_black_frames", "artifact": "export_output" }
  ],
  "judges": [
    {
      "id": "short_export_visual_quality",
      "rubric_id": "export_visual_quality",
      "artifact_labels": ["export_output"],
      "prompt": "You are grading a short-form exported video artifact. Respond with JSON only using keys status, score, confidence, explanation. Determine whether the vertical export appears coherent, free of obvious corruption, and visually consistent with a valid short-form render."
    }
  ]
}
